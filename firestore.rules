rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Phase 4: Entity Validation Blueprints
    function isValidStudent(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100 &&
             data.xp is int && data.xp >= 0 &&
             data.level is string && data.level in ['Tập sự', 'Chuyên gia', 'Bác học'] &&
             (data.keys().hasAll(['displayName', 'xp', 'level']) && data.keys().size() >= 3);
    }

    function isValidMessage(data) {
      return data.studentId == request.auth.uid &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time;
    }

    function isValidDocument(data) {
      return data.title is string && data.title.size() > 0 &&
             data.chunkCount is int &&
             data.uploadedAt == request.time;
    }

    function isValidChunk(data) {
      return data.docId is string &&
             data.content is string && data.content.size() > 0;
    }

    function isValidResult(data) {
      return data.username is string &&
             data.score is int &&
             data.createdAt == request.time;
    }

    // 1. Students Collection
    match /students/{studentId} {
      allow get: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow list: if isSignedIn();
      allow create: if isOwner(studentId) && isValidStudent(incoming());
      allow update: if isOwner(studentId) && isValidStudent(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'xp', 'level', 'displayName', 'lastActive', 'photoURL',
          'streak', 'lastLoginDate', 'badges', 'completedChallenges'
        ])
      ) || isAdmin();
    }

    // 2. Chat Messages
    match /messages/{msgId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update, delete: if isAdmin();
    }

    // 3. Knowledge Base Documents (RAG)
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidDocument(incoming());
    }

    match /knowledge_base/{chunkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidChunk(incoming());
    }

    // 4. Quizzes
    match /quizzes/{quizId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 5. Arena Results
    match /arena_results/{resultId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidResult(incoming());
      allow update, delete: if isAdmin();
    }

    // 6. Admin Access Control
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == adminId; 
    }

    // 7. System Config
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
